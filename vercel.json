{
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node@3.2.0",
      "config": { "nodeVersion": "20.x" }
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/subscribe", "dest": "/api/subscribe.js" },
    { "src": "/api/cal-webhook", "dest": "/api/cal-webhook.js" },
    { "src": "/parent-seminar-for-teens", "dest": "/parent-seminar-for-teens.html" },
    { "src": "/eric-park.png", "dest": "/eric-park.png" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
